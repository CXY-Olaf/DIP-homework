!data/*/checkpoints/debug_images/epoch_0199.png
data/*/checkpoints/*.mp4

# Generated reprojection visualizations (re-runnable by Task 1 debug script).
# Keep one representative example to embed in the README.
data/*/projections/*
!data/*/projections/r_0.png

